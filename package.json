{
  "name": "mcp-sentinel",
  "version": "0.1.3",
  "description": "Audit and enforce security policies on MCP servers — policy engine, drift detection, CI/CD gate",
  "author": "Gustavo Aragon (@oktsec)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "mcp-sentinel": "bin/mcp-sentinel.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.57.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oktsec/mcp-sentinel.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "policy",
    "scanner",
