{
  "name": "mcp-inspector",
  "version": "0.1.0",
  "description": "Scan MCP servers to detect exposed tools, destructive operations, and security risks",
  "author": "Gustavo Aragon (@oktsec)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-inspector": "./bin/mcp-inspector.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.57.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oktsec/mcp-inspector"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "cli",
    "audit",
    "ai-safety"
  ]
}
